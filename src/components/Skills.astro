---

<div class="w-full p-4 md:p-8">
  <div class="grid gap-y-4">
    {skillsData.skills.map((cat) => (
      <div class="group flex flex-col md:flex-row md:items-start gap-4 md:gap-8 rounded-interactive p-4 hover:bg-hover transition-all duration-200">
        
        <!-- Category Column -->
        <div class="md:w-44 lg:w-48 shrink-0 mt-1">
          <h3 class="text-lg text-primary-foreground font-semibold tracking-widest">{cat.category}</h3>
        </div>
        
        <!-- Skill tags layout -->
        <div class="flex flex-wrap gap-2">
          {cat.items.map((item) => (
            <span class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium tracking-wide bg-secondary/30 border border-edge rounded-interactive text-primary-foreground/80 hover:text-accent hover:border-accent hover:bg-accent/5 duration-200 cursor-default select-none transition-all">
              <span class="w-4 h-4 text-primary-foreground/50 hover:text-accent duration-200 transition-all flex items-center justify-center">
                <Fragment set:html={skillLogos[item.logo]} />
              </span>
              {item.name}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>
